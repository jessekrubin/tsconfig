{
  "name": "@jsse/tsconfig",
  "type": "module",
  "version": "0.5.1",
  "description": "tsconfig",
  "author": "jessekrubin <jessekrubin@gmail.com>",
  "license": "MIT",
  "keywords": [
    "jawascript",
    "typescript",
    "tsconfig",
    "config"
  ],
  "exports": {
    ".": "./tsconfig.json",
    "./package.json": "./package.json",
    "./tsconfig.json": "./tsconfig.json",
    "./tsconfig.cjs.json": "./tsconfig.cjs.json",
    "./tsconfig.strict-cjs.json": "./tsconfig.strict-cjs.json",
    "./tsconfig.strict.json": "./tsconfig.strict.json",
    "./cjs": "./tsconfig.cjs.json",
    "./cjs.json": "./tsconfig.cjs.json",
    "./strict-cjs": "./tsconfig.strict-cjs.json",
    "./strict-cjs.json": "./tsconfig.strict-cjs.json",
    "./strict": "./tsconfig.strict.json",
    "./strict.json": "./tsconfig.strict.json",
    "./*": "./*",
    "./tsconfig.schema.json": "./tsconfig.schema.json",
    "./schema": "./tsconfig.schema.json",
    "./schema.json": "./tsconfig.schema.json"
  },
  "files": [
    "README.md",
    "license",
    "package.json",
    "tsconfig.cjs.json",
    "tsconfig.json",
    "tsconfig.schema.json",
    "tsconfig.strict-cjs.json",
    "tsconfig.strict.json"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "pnpm run gen && pnpm run test && publint",
    "gen": "tsx scripts/update-pkg-json-exports.ts",
    "check": "eslint . && prettier --check --object-wrap=collapse .",
    "fmt": "prettier --write --object-wrap=collapse .",
    "fmtc": "prettier --check --object-wrap=collapse .",
    "lint": "eslint .",
    "test": "node --test ./tests/jsse-tsconfig.test.ts",
    "tsc": "tsc -p tsconfig.json",
    "prepack": "npm run build",
    "typecheck": "tsc --noEmit -p tsconfig.build.json"
  },
  "devDependencies": {
    "@jsse/eslint-config": "^0.8.5",
    "@types/node": "^24.13.2",
    "eslint": "^10.6.0",
    "prettier": "^3.9.4",
    "publint": "^0.3.21",
    "tsx": "^4.22.5",
    "typescript": "^6.0.3"
  }
}
