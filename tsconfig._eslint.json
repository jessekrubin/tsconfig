{
  "$schema": "https://www.schemastore.org/tsconfig",
  "extends": "./tsconfig.json",
  "compilerOptions": { "lib": ["es2023"], "types": ["node"] },
  "include": [
    "**/*.ts",
    "./*.cjs",
    "./*.config.cjs",
    "./*.config.cts",
    "./*.config.js",
    "./*.config.mjs",
    "./*.config.mts",
    "./*.config.ts",
    "./*.js",
    "./*.mjs",
    "./*.mts",
    "./*.ts",
    "./.*.cjs",
    "./.eslintrc.cjs",
    "./.eslintrc.js",
    "./scripts/**/*.ts",
    "./tests/**/*.ts"
  ],
  "exclude": ["./fixtures/**/*.*"]
}
